@model List<AssiDay02MVC.Models.Student>

@{
    ViewBag.Title = "All Students";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>All Students</h2>
        <a asp-action="Add" class="btn btn-success">+ Add Student</a>
    </div>

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Age</th>
                <th>Department</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var student in Model)
            {
                <tr>
                    <td>@student.Id</td>
                    <td>@student.Name</td>
                    <td>@student.Age</td>
                    <td>@student.Department?.Name</td>
                    <td>
                        <a asp-action="ShowDetails" asp-route-id="@student.Id"
                           class="btn btn-info btn-sm">Details</a>

                        <a asp-action="Edit" asp-route-id="@student.Id"
                           class="btn btn-warning btn-sm">Edit</a>

                        <a asp-action="Delete" asp-route-id="@student.Id"
                           class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>