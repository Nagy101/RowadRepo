@model AssiDay02MVC.Models.Student

@{
    ViewBag.Title = "Delete Student";
}

<div class="container mt-4">
    <div class="alert alert-danger">
        <h4>⚠️ Are you sure you want to delete this student?</h4>
    </div>

    <div class="card">
        <div class="card-body">
            <p><strong>ID:</strong> @Model.Id</p>
            <p><strong>Name:</strong> @Model.Name</p>
            <p><strong>Age:</strong> @Model.Age</p>
            <p><strong>Department:</strong> @Model.Department?.Name</p>
        </div>
    </div>

    <div class="mt-3">
        @* بيبعت POST لـ Delete Action *@
        <form asp-action="Delete" method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger">Yes, Delete</button>
            <a asp-action="ShowAll" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>