@model AssiDay02MVC.Models.Student

<h2>Student Details</h2>

<p><strong>ID:</strong> @Model.Id</p>
<p><strong>Name:</strong> @Model.Name</p>
<p><strong>Age:</strong> @Model.Age</p>
<p><strong>Department:</strong> @Model.Department?.Name</p>

<h3>Courses</h3>

@if (Model.StuCrs != null && Model.StuCrs.Count > 0)
{
    <table class="table">
        <thead>
            <tr>
                <th>Course</th>
                <th>Degree</th>
                <th>Result</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.StuCrs)
            {
                <tr>
                    <td>@item.Course?.Name</td>
                    <td>@item.Grade</td>
                    <td>
                        <a asp-controller="Course"
                           asp-action="StudentCourseDegree"
                           asp-route-studentId="@Model.Id"
                           asp-route-courseId="@item.CourseId"
                           class="btn btn-outline-primary btn-sm">View Result</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No courses registered.</p>
}

<a href="/Student/ShowAll">Back</a>