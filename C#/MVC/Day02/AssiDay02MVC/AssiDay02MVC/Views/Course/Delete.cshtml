@model AssiDay02MVC.Models.Courses

@{
    ViewData["Title"] = "Delete Course";
}

<h2>Delete Course</h2>
<hr />

<div class="alert alert-warning">
    Are you sure you want to delete this course?
</div>

<div class="card p-3 mb-3">
    <p><strong>Name:</strong> @Model.Name</p>
    <p><strong>Degree:</strong> @Model.Degree</p>
    <p><strong>Min Degree:</strong> @Model.MinDegree</p>
    <p><strong>Department:</strong> @Model.Department?.Name</p>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="ShowAll" class="btn btn-secondary">Cancel</a>
</form>
